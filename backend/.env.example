# Application
APP_NAME=ContaFlow
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
APP_ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://contaflow:contaflow@localhost:5432/contaflow
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# JWT
JWT_SECRET_KEY=change-this-jwt-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage (S3-compatible: AWS S3, Cloudflare R2, MinIO)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_S3_BUCKET=contaflow-reports
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_ENDPOINT_URL=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@contaflow.com

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Observability
LOG_LEVEL=INFO
SENTRY_DSN=
